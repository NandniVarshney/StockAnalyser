# ─── StockAnalyser — environment variables ────────────────────────────────
# Copy to `.env` and fill in your values. Never commit `.env`.

# ─── App ───────────────────────────────────────────────────────────────────
APP_PORT=8000
LOG_LEVEL=INFO

# ─── Storage ───────────────────────────────────────────────────────────────
SQLITE_PATH=db/stockanalyser.db
PARQUET_DIR=data/ohlcv

# ─── Behaviour (swing mode — daily only) ──────────────────────────────────
TIMEZONE=Asia/Kolkata
FUNDAMENTALS_TTL_HOURS=24
OHLCV_BACKFILL_YEARS=2
NEWS_RETENTION_DAYS=30

# ─── Rovo Dev CLI (matches disturbed-partner baseline) ────────────────────
ROVODEV_SERVE_PORT=8766
ROVODEV_BASE_URL=http://localhost:8766
# ROVODEV_BINARY_PATH=                    # auto-detect `acli` from PATH if blank
# ROVODEV_WORKING_DIR=                    # defaults to cwd
REQUEST_TIMEOUT_MS=180000                  # 3 min — whole orchestrator call
PER_AGENT_TIMEOUT_SEC=120                  # 2 min — per agent
AGGREGATOR_USE_LLM_REASONING=false         # keep deterministic in Phase 1

# ─── Atlassian context (read by `acli rovodev serve`) ─────────────────────
ATLASSIAN_SITE=
ATLASSIAN_CLOUD_ID=
ATLASSIAN_API_TOKEN=
ATLASSIAN_ACCOUNT_ID=

# ─── External data API keys ────────────────────────────────────────────────
FINNHUB_API_KEY=
NEWSDATA_API_KEY=
