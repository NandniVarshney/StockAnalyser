# ─── StockAnalyser — local environment ────────────────────────────────────
# Copy to .env. Almost everything has sensible defaults.

# ─── Service ports ────────────────────────────────────────────────────────
APP_PORT=8000
ROVODEV_SERVE_PORT=8766
ROVODEV_BASE_URL=http://localhost:8766

# ─── Behaviour ────────────────────────────────────────────────────────────
TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO

# How many years of daily candles to backfill on first run per symbol
OHLCV_BACKFILL_YEARS=2

# Fundamentals cache TTL (Screener.in)
FUNDAMENTALS_TTL_HOURS=24

# News retention before cleanup_news job drops them
NEWS_RETENTION_DAYS=30

# ─── Storage paths (used by SQLAlchemy + Parquet) ─────────────────────────
SQLITE_PATH=db/stockanalyser.db
PARQUET_DIR=data/ohlcv

# ─── Rovo Dev CLI timing ──────────────────────────────────────────────────
REQUEST_TIMEOUT_MS=180000
PER_AGENT_TIMEOUT_SEC=120

# Aggregator is deterministic Python by default. Phase 2 can flip this on
# to also get an LLM-generated polish line.
AGGREGATOR_USE_LLM_REASONING=false

# ─── External data API keys ───────────────────────────────────────────────
# Phase 1 has NO required keys. nselib, yfinance, Screener.in and RSS feeds
# are all free + key-less for Indian stocks.
